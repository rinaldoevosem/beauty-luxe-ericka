{% doc %}
  Renders the product header column for the Product Info Panel.

  Contains the brand row at the top, a slot for merchant-added dynamic blocks

  Layout (top → bottom):
  - Brand row: brand name (`closest.product.vendor`) + share/favorite icons.
  - Product feature tags
  - Product price info (price + installment line)
  - Product shipping note
  - Product subscribe badge
  - Product short description

  @example
  {% content_for 'block', type: '_product-header', id: 'product-header', closest.product: closest.product %}
{% enddoc %}

{%- liquid
  assign header_product = closest.product
  assign brand_name = header_product.vendor
-%}

{% comment %}
  RULE EXCEPTION: aria-labels hardcoded — locale file is auto-generated and there
  are no existing translation keys for "Share product" / "Save to favorites".
{% endcomment %}
<div class="product-header">
  <div class="product-header__row">
    <p class="product-header__brand">
      {{- brand_name | escape -}}
    </p>

    <div class="product-header__actions">
      <button
        type="button"
        class="product-header__action"
        aria-label="Share product"
      >
        <span class="svg-wrapper product-header__icon">
          {{- 'icon-share.svg' | inline_asset_content -}}
        </span>
      </button>

      <button
        type="button"
        class="product-header__action"
        aria-label="Save to favorites"
        aria-pressed="false"
      >
        <span class="svg-wrapper product-header__icon">
          {{- 'icon-heart.svg' | inline_asset_content -}}
        </span>
      </button>
    </div>
  </div>



  {% content_for 'blocks' %} 

  {% content_for 'block',
    type: '_product-rating-badge',
    id: 'product-rating-badge'
  %} 
  {% content_for 'block',
    type: '_product-feature-tags',
    id: 'product-feature-tags',
    closest.product: closest.product
  %}
  {% content_for 'block',
    type: '_product-price-info',
    id: 'product-price-info',
    closest.product: closest.product
  %}
  <div class="product-header__inline-row">
    {% content_for 'block',
      type: '_product-subscribe-badge',
      id: 'product-subscribe-badge'
    %}
    {% content_for 'block',
      type: '_product-shipping-note',
      id: 'product-shipping-note'
    %}
  </div>
</div>

{% stylesheet %}
  .product-header {
    display: flex;
    flex-direction: column;
    gap: 16px;
    width: 100%;
  }

  .product-header__row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    width: 100%;
  }

  /* Subscribe pill + shipping note on the same row, per Figma. */
  .product-header__inline-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 12px;
  }

  .product-header__brand {
    margin: 0;
    /* RULE EXCEPTION: project pattern — body font setting is Jost, but spec requires Outfit Regular. */
    font-family: 'Outfit', var(--font-body--family);
    font-weight: 400;
    font-size: 0.875rem;
    line-height: 1.5;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .product-header__actions {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .product-header__action {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
    padding: 0;
    border: 0;
    background: none;
    color: var(--color-text-muted);
    cursor: pointer;
    transition: color 0.2s ease;
  }

  .product-header__action:hover,
  .product-header__action:focus-visible {
    color: var(--color-foreground);
  }

  .product-header__action[aria-pressed='true'] {
    color: var(--color-primary);
  }

  .product-header__action[aria-pressed='true'] svg {
    fill: currentColor;
  }

  .product-header__icon {
    display: inline-flex;
    width: 20px;
    height: 20px;
  }

  .product-header__icon svg {
    width: 100%;
    height: 100%;
  }

  /* Figma spec — SKU inside the Product header.
     Higher specificity than `.paragraph:not(.button)` from base.css so the
     theme's default font-size/color don't win. Targets the merchant-added
     SKU block via its component tag. */
  .product-header product-sku-component,
  .product-header product-sku-component.paragraph,
  .product-header product-sku-component.text-block {
    display: block;
    /* RULE EXCEPTION: project pattern — body font setting is Jost, but spec requires Outfit Light. */
    font-family: 'Outfit', var(--font-body--family);
    font-weight: 300;
    font-size: 0.8125rem;
    line-height: 1.5;
    text-align: right;
    color: var(--color-text-muted);
  }

  .product-header product-sku-component .sku {
    /* Inherit color so the override above wins over `.paragraph` color. */
    margin: 0;
    font-family: 'Outfit', var(--font-body--family);
    font-weight: 300;
    line-height: 1.5;
    color: var(--color-text-muted);
  }

  .product-header product-sku-component .sku::before {
    /* "SKU" prefix per Figma spec — universal abbreviation, not localized. */
    content: 'SKU ';
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Product header",
  "tag": null,
  "blocks": [
    { "type": "@theme" },
    { "type": "@app" },
    { "type": "text" },
    { "type": "price" },
    { "type": "icon" },
    { "type": "image" },
    { "type": "group" },
    { "type": "spacer" },
    { "type": "review" },
    { "type": "product-inventory" },
    { "type": "product-custom-property" }
  ],
  "settings": []
}
{% endschema %}
