{% doc %}
  Renders the "Subscribe & Save" pill badge.

  Visual badge per Figma spec. Subscription functionality requires a third-party
  app integration (ReCharge, Bold, or Shopify native subscriptions). The discount
  percentage is configurable per block.

  @example
  {% content_for 'block', type: '_product-subscribe-badge', id: 'product-subscribe-badge' %}
{% enddoc %}

{%- liquid
  assign discount_percent = block.settings.discount_percent | default: 5
  assign label = block.settings.label | default: 'Subscribe & Save'
-%}

<div class="product-subscribe-badge" role="note">
  <span class="svg-wrapper product-subscribe-badge__icon">
    {{- 'iconsubscribe.svg' | inline_asset_content -}}
  </span>
  <span class="product-subscribe-badge__label">
    {{- label }} {{ discount_percent }}%
  </span>
</div>

{% stylesheet %}
  .product-subscribe-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 3px 8px;
    background-color: var(--color-success-soft);
    border: 1px solid var(--color-success);
    border-radius: 50px;
    max-width: 156px;
  }

  .product-subscribe-badge__icon {
    display: inline-flex;
    flex-shrink: 0;
    width: 16px;
    height: 16px;
    color: var(--color-success);
  }

  .product-subscribe-badge__icon svg {
    width: 100%;
    height: 100%;
  }

  .product-subscribe-badge__label {
    /* RULE EXCEPTION: project pattern — body font setting is Jost, but spec requires Outfit Regular. */
    font-family: 'Outfit', var(--font-body--family);
    font-weight: 400;
    font-size: 0.8125rem;
    line-height: 1.4;
    color: var(--color-success);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Product subscribe badge",
  "tag": null,
  "settings": [
    {
      "type": "paragraph",
      "content": "Visual badge only. Connect a subscription app (ReCharge, Bold, or Shopify Subscriptions) for the actual subscribe-and-save flow."
    },
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "Subscribe & Save"
    },
    {
      "type": "range",
      "id": "discount_percent",
      "label": "Discount %",
      "min": 1,
      "max": 50,
      "step": 1,
      "default": 5
    }
  ]
}
{% endschema %}
