{% doc %}
  Renders the cart drawer machinery in one place: trigger button, dialog, scripts.

  When `settings.cart_type == 'drawer'` and we're not on the cart page, the trigger
  is a <button> wrapped in <cart-drawer-component auto-open> so that:
  - clicking it opens the drawer (`on:click="/open"`),
  - the cart auto-opens after add-to-cart events when `settings.auto_open_cart_drawer` is on.

  Otherwise the trigger renders as a plain link to `/cart`.

  In both modes the count is rendered inside <cart-icon> so it updates live via cart-icon.js.

  @param {string} [trigger_class] - CSS class applied to the trigger button/link.
  @param {string} [icon_asset]    - SVG asset filename for the icon. Default: 'icon-cart.svg'.
  @param {string} [icon_class]    - CSS class for the icon's <span> wrapper.
  @param {string} [label]         - Visible label text rendered after the icon.
  @param {string} [label_class]   - CSS class for the label <span>.
  @param {string} [aria_label]    - Override aria-label. Default: localized "cart" + count.

  @example
  {% render 'cart-drawer-trigger',
     trigger_class: 'header-bar__action-link',
     icon_asset:    'Cart-Icon.svg',
     icon_class:    'header-bar__icon',
     label:         'Bag',
     label_class:   'header-bar__action-label' %}
{% enddoc %}

{%- liquid
  assign use_drawer = false
  if settings.cart_type == 'drawer' and template.name != 'cart'
    assign use_drawer = true
  endif

  assign resolved_icon_asset = icon_asset | default: 'icon-cart.svg'

  capture default_aria
    echo aria_label | default: 'accessibility.cart' | t
    if cart.item_count > 0
      echo ', '
      echo cart.item_count
    endif
  endcapture
-%}

<script
  src="{{ 'cart-icon.js' | asset_url }}"
  type="module"
  fetchpriority="low"
></script>

{%- capture cart_icon_inner -%}
  <cart-icon
    class="cart-drawer-trigger__icon-host{% unless cart == empty %} cart-drawer-trigger__icon-host--has-cart{% endunless %}"
    data-testid="cart-icon"
  >
    <span
      class="svg-wrapper {{ icon_class }}"
      aria-hidden="true"
    >
      {{ resolved_icon_asset | inline_asset_content }}
    </span>
    {%- if label != blank -%}
      <span class="{{ label_class }}">{{ label }}</span>
    {%- endif -%}
    {% render 'cart-bubble', limit: 100 %}
  </cart-icon>
{%- endcapture -%}

{%- if use_drawer -%}
  <script
    src="{{ 'cart-drawer.js' | asset_url }}"
    type="module"
    fetchpriority="low"
  ></script>

  {%- capture empty_cart_drawer_content -%}
    <div class="cart-drawer__header">
      <button
        ref="closeButton"
        on:click="cart-drawer-component/close"
        class="button close-button cart-drawer__close-button button-unstyled"
        aria-label="{{ 'actions.close_dialog' | t }}"
      >
        <span class="svg-wrapper">
          {{- 'icon-close.svg' | inline_asset_content -}}
        </span>
      </button>
    </div>

    <div
      class="cart-drawer__content"
      aria-label="{{ 'accessibility.cart' | t }}"
    >
      <h2
        class="cart-drawer__heading h4 cart-drawer__heading--empty"
        id="cart-drawer-heading-empty"
      >
        {{ 'content.your_cart_is_empty' | t }}
      </h2>

      <div class="cart-drawer__items">
        {% render 'cart-products', force_empty: true %}
      </div>
    </div>
  {%- endcapture -%}

  <cart-drawer-component
    class="cart-drawer cart-drawer-trigger"
    {% if settings.auto_open_cart_drawer %}auto-open{% endif %}
  >
    <template id="empty-cart-template">
      {{ empty_cart_drawer_content }}
    </template>

    <button
      type="button"
      class="{{ trigger_class }}"
      on:click="/open"
      aria-haspopup="dialog"
      aria-label="{{ default_aria | strip }}"
      aria-describedby="cart-bubble-text"
      data-testid="cart-drawer-trigger"
    >
      {{ cart_icon_inner }}
    </button>

    <dialog
      ref="dialog"
      class="cart-drawer__dialog dialog-modal dialog-drawer color-{{ settings.drawer_color_scheme }}{% if cart.empty? %} cart-drawer--empty{% endif %}"
      data-testid="cart-drawer-dialog"
      aria-labelledby="{% if cart.empty? %}cart-drawer-heading-empty{% else %}cart-drawer-heading{% endif %}"
      scroll-lock
      cart-summary-sticky="true"
    >
      <span
        ref="liveRegion"
        class="visually-hidden"
        role="status"
      ></span>
      <div
        class="cart-drawer__inner"
        data-hydration-key="cart-drawer-inner"
      >
        {%- capture cart_items_children -%}
          {%- if cart.empty? -%}
            {{ empty_cart_drawer_content }}
          {%- else -%}
            <div
              class="cart-drawer__header"
              id="cart-drawer-header"
            >
              <h2
                class="cart-drawer__heading h4"
                id="cart-drawer-heading"
              >
                {{ 'content.cart_title' | t }}
                {% render 'cart-bubble' %}
              </h2>

              <button
                ref="closeButton"
                on:click="cart-drawer-component/close"
                class="button close-button cart-drawer__close-button button-unstyled"
                aria-label="{{ 'actions.close_dialog' | t }}"
              >
                <span class="svg-wrapper">
                  {{- 'icon-close.svg' | inline_asset_content -}}
                </span>
              </button>
            </div>

            <scroll-hint
              class="cart-drawer__content"
              aria-label="{{ 'accessibility.cart' | t }}"
              style="--header-height: 60px;"
            >
              <scroll-hint class="cart-drawer__items">
                {% render 'cart-products' %}
              </scroll-hint>

              <div class="cart-drawer__summary">
                {% render 'cart-summary', section_id: section.id %}
              </div>
            </scroll-hint>
          {%- endif -%}
        {%- endcapture -%}
        {% render 'cart-items-component',
          children: cart_items_children,
          is_drawer: true,
          section_id: section.id
        %}
      </div>
    </dialog>
  </cart-drawer-component>
{%- else -%}
  <a
    href="{{ routes.cart_url }}"
    class="{{ trigger_class }}"
    aria-label="{{ default_aria | strip }}"
    aria-describedby="cart-bubble-text"
  >
    {{ cart_icon_inner }}
  </a>
{%- endif -%}
