{% doc %}
  Beauty Luxe mobile menu drawer.

  Renders a left-side slide-in dialog with the merchant-selected linklist.
  Triggered from the header bar's hamburger button via
  `on:click="menu-drawer-component/showDialog"`.

  @param {object} linklist  - Linklist object to render. Falls back to "main-menu" when blank.
  @param {string} [brand]   - Brand wordmark shown at the top of the drawer.

  @example
  {% render 'menu-drawer', linklist: linklists[section.settings.menu], brand: brand %}
{% enddoc %}

{%- liquid
  if linklist == blank or linklist.links == empty
    assign linklist = linklists['main-menu']
  endif
-%}

<script
  src="{{ 'menu-drawer-component.js' | asset_url }}"
  type="module"
  fetchpriority="low"
></script>

<menu-drawer-component
  id="menu-drawer"
  class="menu-drawer-component"
>
  <dialog
    ref="dialog"
    class="menu-drawer__dialog dialog-modal dialog-drawer color-{{ settings.popover_color_scheme }}"
    aria-labelledby="menu-drawer-heading"
    scroll-lock
  >
    <div class="menu-drawer__inner">
      <div class="menu-drawer__header">
        <h2
          id="menu-drawer-heading"
          class="menu-drawer__brand"
        >
          {{- brand | default: shop.name | escape -}}
        </h2>
        <button
          type="button"
          class="button button-unstyled menu-drawer__close-button"
          on:click="/closeDialog"
          aria-label="{{ 'actions.close' | t }}"
        >
          <span class="svg-wrapper">
            {{- 'icon-close.svg' | inline_asset_content -}}
          </span>
        </button>
      </div>

      <nav
        class="menu-drawer__nav"
        aria-label="{{ 'accessibility.header_navigation_label' | t }}"
      >
        <ul
          class="menu-drawer__list"
          role="list"
        >
          {%- for link in linklist.links -%}
            <li class="menu-drawer__item">
              {%- if link.links.size > 0 -%}
                <details class="menu-drawer__details">
                  <summary class="menu-drawer__summary">
                    <span>{{ link.title | escape }}</span>
                    <span
                      class="svg-wrapper menu-drawer__summary-icon"
                      aria-hidden="true"
                    >
                      {{- 'icon-plus.svg' | inline_asset_content -}}
                    </span>
                  </summary>
                  <ul
                    class="menu-drawer__sublist"
                    role="list"
                  >
                    {%- for sublink in link.links -%}
                      <li class="menu-drawer__subitem">
                        <a
                          href="{{ sublink.url }}"
                          class="menu-drawer__sublink{% if sublink.current %} menu-drawer__sublink--active{% endif %}"
                          {% if sublink.current %}
                            aria-current="page"
                          {% endif %}
                        >
                          {{- sublink.title | escape -}}
                        </a>
                      </li>
                    {%- endfor -%}
                  </ul>
                </details>
              {%- else -%}
                <a
                  href="{{ link.url }}"
                  class="menu-drawer__link{% if link.current %} menu-drawer__link--active{% endif %}"
                  {% if link.current %}
                    aria-current="page"
                  {% endif %}
                >
                  {{- link.title | escape -}}
                </a>
              {%- endif -%}
            </li>
          {%- endfor -%}
        </ul>
      </nav>
    </div>
  </dialog>
</menu-drawer-component>

{% stylesheet %}
  /* Mobile menu drawer — slides in from the left. Uses Horizon's
     dialog-modal/dialog-drawer base classes for animation timings. */
  .menu-drawer-component {
    display: contents;
  }

  .menu-drawer__dialog {
    position: fixed;
    top: 0;
    left: 0;
    margin: 0;
    padding: 0;
    width: min(85vw, 380px);
    height: 100%;
    border: none;
    border-right: var(--style-border-drawer);
    border-radius: 0;
    box-shadow: var(--shadow-drawer);
    background-color: var(--color-background);
    color: var(--color-foreground);
    overflow: hidden;
  }

  .menu-drawer__dialog:modal {
    max-height: 100dvh;
  }

  .menu-drawer__inner {
    display: flex;
    flex-direction: column;
    height: 100%;
    overflow: hidden;
  }

  .menu-drawer__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 16px 20px;
    border-bottom: 1px solid var(--color-border, #E7E7E7);
    flex-shrink: 0;
  }

  .menu-drawer__brand {
    margin: 0;
    font-family: var(--font-ui, var(--font-heading--family));
    font-size: 18px;
    font-weight: 600;
    line-height: 1.2;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-foreground);
  }

  .menu-drawer__close-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    padding: 0;
    border: none;
    background: transparent;
    color: var(--color-foreground);
    cursor: pointer;
    border-radius: 50%;
  }

  .menu-drawer__close-button:hover,
  .menu-drawer__close-button:focus-visible {
    background-color: rgb(var(--color-foreground-rgb) / 0.06);
  }

  .menu-drawer__close-button .svg-wrapper {
    width: 20px;
    height: 20px;
  }

  .menu-drawer__close-button svg {
    width: 100%;
    height: 100%;
  }

  .menu-drawer__nav {
    flex: 1 1 auto;
    overflow-y: auto;
    padding: 8px 0;
  }

  .menu-drawer__list,
  .menu-drawer__sublist {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .menu-drawer__item {
    border-bottom: 1px solid var(--color-border, #E7E7E7);
  }

  .menu-drawer__link,
  .menu-drawer__summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 16px 20px;
    color: var(--color-foreground);
    text-decoration: none;
    font-family: var(--font-body--family);
    font-size: 16px;
    font-weight: 400;
    line-height: 1.4;
    cursor: pointer;
    list-style: none;
  }

  .menu-drawer__summary::-webkit-details-marker {
    display: none;
  }

  .menu-drawer__link:hover,
  .menu-drawer__summary:hover,
  .menu-drawer__link:focus-visible,
  .menu-drawer__summary:focus-visible {
    background-color: rgb(var(--color-foreground-rgb) / 0.04);
  }

  .menu-drawer__link--active,
  .menu-drawer__sublink--active {
    font-weight: 500;
  }

  .menu-drawer__summary-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 18px;
    height: 18px;
    transition: transform 0.2s ease;
  }

  .menu-drawer__summary-icon svg {
    width: 100%;
    height: 100%;
  }

  .menu-drawer__details[open] .menu-drawer__summary-icon {
    transform: rotate(45deg);
  }

  .menu-drawer__sublist {
    background-color: rgb(var(--color-foreground-rgb) / 0.025);
  }

  .menu-drawer__sublink {
    display: block;
    padding: 12px 20px 12px 36px;
    color: var(--color-foreground);
    text-decoration: none;
    font-family: var(--font-body--family);
    font-size: 14px;
    line-height: 1.4;
  }

  .menu-drawer__sublink:hover,
  .menu-drawer__sublink:focus-visible {
    background-color: rgb(var(--color-foreground-rgb) / 0.05);
  }
{% endstylesheet %}
