{% doc %}
  Beauty Luxe header bar.

  - Desktop: text wordmark (left) | pill-shaped search button (center) | sign-in / wishlist / bag (right).
  - Mobile (≤749px): hamburger + wordmark (left) | search / account / wishlist / bag icons (right).
  - Search button opens the existing `<search-modal>` via `on:click="#search-modal/showDialog"`.
  - Hamburger is a placeholder; menu drawer wiring is a follow-up task.

  @example
  Rendered via `sections/header-group.json` with section type `header`.
{% enddoc %}

{%- liquid
  assign brand = section.settings.brand_text
  if brand == blank
    assign brand = shop.name
  endif

  assign search_placeholder = section.settings.search_placeholder
  if search_placeholder == blank
    assign search_placeholder = 'Search'
  endif

  assign wishlist_url = section.settings.wishlist_url
  if wishlist_url == blank
    assign wishlist_url = '#'
  endif

  if customer
    assign account_label = 'Account'
  else
    assign account_label = 'Sign in'
  endif
-%}

<div class="header-bar__brand-group">
  <button
    type="button"
    class="header-bar__menu-toggle"
    on:click="#menu-drawer/showDialog"
    aria-label="Open menu"
    aria-haspopup="dialog"
  >
    <span class="header-bar__icon" aria-hidden="true">
      {{ 'icon-burger.svg' | inline_asset_content }}
    </span>
  </button>

  <a href="{{ routes.root_url }}" class="header-bar__logo">{{ brand | escape }}</a>
</div>

{%- assign mobile_menu = linklists[section.settings.menu] -%}
{% render 'menu-drawer', linklist: mobile_menu, brand: brand %}

{%- if section.settings.show_search -%}
  <button
    type="button"
    class="header-bar__search"
    on:click="#search-modal/showDialog"
    aria-label="Open search"
    aria-haspopup="dialog"
  >
    <span class="header-bar__search-icon" aria-hidden="true">
      {{ 'icon-search.svg' | inline_asset_content }}
    </span>
    <span class="header-bar__search-placeholder">{{ search_placeholder | escape }}</span>
  </button>
{%- endif -%}

<ul class="header-bar__actions" role="list">
  {%- if section.settings.show_search -%}
    <li class="header-bar__action header-bar__action--mobile-only">
      <button
        type="button"
        class="header-bar__action-link"
        on:click="#search-modal/showDialog"
        aria-label="Open search"
        aria-haspopup="dialog"
      >
        <span class="header-bar__icon" aria-hidden="true">
          {{ 'icon-search.svg' | inline_asset_content }}
        </span>
      </button>
    </li>
  {%- endif -%}

  {%- if section.settings.show_account -%}
    <li class="header-bar__action">
      <a href="{{ routes.account_url }}" class="header-bar__action-link">
        <span class="header-bar__icon" aria-hidden="true">
          {{ 'User-Icon.svg' | inline_asset_content }}
        </span>
        <span class="header-bar__action-label">{{ account_label }}</span>
      </a>
    </li>
  {%- endif -%}

  {%- if section.settings.show_wishlist -%}
    <li class="header-bar__action">
      <a href="{{ wishlist_url }}" class="header-bar__action-link">
        <svg class="header-bar__icon" viewBox="0 0 20 20" fill="none" stroke="currentColor" aria-hidden="true">
          {% render 'icon', icon: 'heart' %}
        </svg>
        <span class="header-bar__action-label">Wishlist</span>
      </a>
    </li>
  {%- endif -%}

  <li class="header-bar__action header-bar__action--cart">
    <script
      src="{{ 'cart-icon.js' | asset_url }}"
      type="module"
      fetchpriority="low"
    ></script>

    {%- if settings.cart_type == 'drawer' and template.name != 'cart' -%}
      <script
        src="{{ 'cart-drawer.js' | asset_url }}"
        type="module"
        fetchpriority="low"
      ></script>

      {%- capture empty_cart_drawer_content -%}
        <div class="cart-drawer__header">
          <button
            ref="closeButton"
            on:click="cart-drawer-component/close"
            class="button close-button cart-drawer__close-button button-unstyled"
            aria-label="{{ 'actions.close_dialog' | t }}"
          >
            <span class="svg-wrapper">
              {{- 'icon-close.svg' | inline_asset_content -}}
            </span>
          </button>
        </div>

        <div
          class="cart-drawer__content"
          aria-label="{{ 'accessibility.cart' | t }}"
        >
          <h2
            class="cart-drawer__heading h4 cart-drawer__heading--empty"
            id="cart-drawer-heading-empty"
          >
            {{ 'content.your_cart_is_empty' | t }}
          </h2>

          <div class="cart-drawer__items">
            {% render 'cart-products', force_empty: true %}
          </div>
        </div>
      {%- endcapture -%}

      <cart-drawer-component
        class="cart-drawer header-bar__cart-drawer"
        {% if settings.auto_open_cart_drawer %}auto-open{% endif %}
      >
        <template id="empty-cart-template">
          {{ empty_cart_drawer_content }}
        </template>

        <button
          type="button"
          class="header-bar__action-link"
          on:click="/open"
          aria-haspopup="dialog"
          aria-label="Bag{% if cart.item_count > 0 %}, {{ cart.item_count }}{% endif %}"
          aria-describedby="cart-bubble-text"
          data-testid="cart-drawer-trigger"
        >
          <cart-icon
            class="header-bar__cart-icon{% unless cart == empty %} header-bar__cart-icon--has-cart{% endunless %}"
            data-testid="cart-icon"
          >
            <span
              class="header-bar__icon"
              aria-hidden="true"
            >
              {{ 'Cart-Icon.svg' | inline_asset_content }}
            </span>
            <span class="header-bar__action-label">Bag</span>
            {% render 'cart-bubble', limit: 100 %}
          </cart-icon>
        </button>

        <dialog
          ref="dialog"
          class="cart-drawer__dialog dialog-modal dialog-drawer color-{{ settings.drawer_color_scheme }}{% if cart.empty? %} cart-drawer--empty{% endif %}"
          data-testid="cart-drawer-dialog"
          aria-labelledby="{% if cart.empty? %}cart-drawer-heading-empty{% else %}cart-drawer-heading{% endif %}"
          scroll-lock
          cart-summary-sticky="true"
        >
          <span
            ref="liveRegion"
            class="visually-hidden"
            role="status"
          ></span>
          <div
            class="cart-drawer__inner"
            data-hydration-key="cart-drawer-inner"
          >
            {%- capture cart_items_children -%}
              {%- if cart.empty? -%}
                {{ empty_cart_drawer_content }}
              {%- else -%}
                <div
                  class="cart-drawer__header"
                  id="cart-drawer-header"
                >
                  <h2
                    class="cart-drawer__heading h4"
                    id="cart-drawer-heading"
                  >
                    {{ 'content.cart_title' | t }}
                    {% render 'cart-bubble' %}
                  </h2>

                  <button
                    ref="closeButton"
                    on:click="cart-drawer-component/close"
                    class="button close-button cart-drawer__close-button button-unstyled"
                    aria-label="{{ 'actions.close_dialog' | t }}"
                  >
                    <span class="svg-wrapper">
                      {{- 'icon-close.svg' | inline_asset_content -}}
                    </span>
                  </button>
                </div>

                <scroll-hint
                  class="cart-drawer__content"
                  aria-label="{{ 'accessibility.cart' | t }}"
                  style="--header-height: 60px;"
                >
                  <scroll-hint class="cart-drawer__items">
                    {% render 'cart-products' %}
                  </scroll-hint>

                  <div class="cart-drawer__summary">
                    {% render 'cart-summary', section_id: section.id %}
                  </div>
                </scroll-hint>
              {%- endif -%}
            {%- endcapture -%}
            {% render 'cart-items-component',
              children: cart_items_children,
              is_drawer: true,
              section_id: section.id
            %}
          </div>
        </dialog>
      </cart-drawer-component>
    {%- else -%}
      <a
        href="{{ routes.cart_url }}"
        class="header-bar__action-link"
        aria-label="Bag{% if cart.item_count > 0 %}, {{ cart.item_count }}{% endif %}"
        aria-describedby="cart-bubble-text"
      >
        <cart-icon
          class="header-bar__cart-icon{% unless cart == empty %} header-bar__cart-icon--has-cart{% endunless %}"
          data-testid="cart-icon"
        >
          <span
            class="header-bar__icon"
            aria-hidden="true"
          >
            {{ 'Cart-Icon.svg' | inline_asset_content }}
          </span>
          <span class="header-bar__action-label">Bag</span>
          {% render 'cart-bubble', limit: 100 %}
        </cart-icon>
      </a>
    {%- endif -%}
  </li>
</ul>

{% stylesheet %}
  .header-bar {
    display: flex;
    align-items: center;
    inline-size: 100%;
    gap: 24px;
    padding: 12px 30px;
    background-color: var(--color-white-100);
    color: var(--color-dark-100);
  }

  .header-bar__brand-group {
    flex: 2;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .header-bar__menu-toggle {
    display: none;
    align-items: center;
    justify-content: center;
    inline-size: 24px;
    block-size: 24px;
    padding: 0;
    border: none;
    background: transparent;
    color: var(--color-dark-100);
    cursor: pointer;
  }

  .header-bar__logo {
    font-family: var(--font-ui);
    font-size: var(--type-logo-size);
    font-weight: var(--type-logo-weight);
    line-height: var(--type-logo-lh);
    color: var(--color-dark-100);
    text-decoration: none;
    white-space: nowrap;
  }

  .header-bar__search {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    inline-size: 310px;
    block-size: 32px;
    padding: 0 12px;
    border: 1px solid var(--color-dark-100);
    border-radius: 50px;
    background: transparent;
    cursor: pointer;
    color: var(--color-dark-60);
    font-family: var(--font-body);
    font-size: var(--type-p-sm-size);
    font-weight: var(--type-p-sm-weight-light);
    line-height: var(--type-p-sm-lh);
  }

  .header-bar__search-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    inline-size: 16px;
    block-size: 16px;
    flex: 0 0 auto;
    color: currentColor;
  }

  .header-bar__search-icon svg {
    inline-size: 100%;
    block-size: 100%;
  }

  .header-bar__search-placeholder {
    color: var(--color-dark-60);
  }

  .header-bar__actions {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 20px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .header-bar__action {
    margin: 0;
  }

  .header-bar__action-link {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 0;
    border: none;
    background: transparent;
    color: var(--color-dark-60);
    text-decoration: none;
    font-family: var(--font-body);
    font-size: var(--type-p-xs-size);
    font-weight: var(--type-p-xs-weight-light);
    line-height: var(--type-p-xs-lh);
    cursor: pointer;
  }

  .header-bar__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    inline-size: 16px;
    block-size: 16px;
    flex: 0 0 auto;
    color: currentColor;
    fill: currentColor;
    stroke: currentColor;
  }

  .header-bar__icon svg {
    inline-size: 100%;
    block-size: 100%;
  }

  .header-bar__action-count {
    position: absolute;
    top: -6px;
    right: -8px;
    min-inline-size: 16px;
    block-size: 16px;
    padding: 0 4px;
    border-radius: 50px;
    background-color: var(--color-dark-100);
    color: var(--color-white-100);
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 500;
    line-height: 16px;
    text-align: center;
  }

  /* Live count badge (Horizon's <cart-bubble> rendered by cart-icon.js).
     Replaces the static .header-bar__action-count so the count updates
     in real time after add-to-cart events. */
  .header-bar__cart-icon {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }

  .header-bar__cart-icon .cart-bubble {
    position: absolute;
    top: -6px;
    right: -8px;
    width: auto;
    min-inline-size: 16px;
    block-size: 16px;
    aspect-ratio: auto;
    padding: 0 4px;
    border-radius: 50px;
    background-color: var(--color-dark-100);
  }

  .header-bar__cart-icon .cart-bubble.visually-hidden {
    display: none;
  }

  .header-bar__cart-icon .cart-bubble__background {
    display: none;
  }

  .header-bar__cart-icon .cart-bubble__text {
    color: var(--color-white-100);
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 500;
    line-height: 16px;
  }

  /* Reset Horizon's button styles inside the brand cart trigger so the
     <button on:click="/open"> looks identical to the previous <a> link. */
  button.header-bar__action-link {
    margin: 0;
    appearance: none;
    text-align: inherit;
  }

  .cart-drawer {
    --cart-drawer-padding: var(--padding-xl) var(--padding-xl);
    --cart-drawer-padding-desktop: var(--padding-xl) var(--padding-2xl);

    @media screen and (min-width: 750px) {
      margin-inline-end: calc(var(--gap-xs) * -1);
    }
  }

  .cart-drawer__dialog {
    position: fixed;
    overflow: hidden;
    border-radius: 0;
    width: 100%;
    height: 100%;
    margin: 0 0 0 auto;
    padding: 0;
    border-left: var(--style-border-drawer);
    box-shadow: var(--shadow-drawer);
    background-color: var(--color-background);

    @media screen and (min-width: 750px) {
      width: var(--sidebar-width);
      max-width: 95vw;
    }
  }

  .cart-drawer__dialog:modal {
    max-height: 100dvh;
    overflow-y: hidden;
  }

  .cart-drawer__inner {
    height: 100%;
    overflow: hidden;
  }

  .cart-drawer__content {
    height: calc(100% - var(--header-height));
    display: flex;
    flex-direction: column;
    padding: 0;
    background-color: var(--color-background);
    flex-grow: 1;
    overflow-y: auto;
  }

  .cart-drawer__heading {
    display: flex;
    align-items: center;
    gap: var(--gap-xs);
    margin-bottom: 0;
  }

  .cart-drawer__close-button {
    margin-right: calc(var(--padding-sm) * -1);
    top: var(--margin-sm);

    @media screen and (max-width: 749px) {
      top: var(--margin-2xs);
    }
  }

  .cart-drawer--empty .cart-drawer__content {
    text-align: center;
    min-height: auto;
  }

  .cart-drawer--empty .cart-drawer__heading {
    margin-bottom: var(--margin-md);
  }

  .cart-drawer__items .cart-items__table-row {
    padding-bottom: var(--gap-xl);
    border-bottom: var(--style-border-width) solid var(--color-border);
    margin-bottom: var(--gap-xl);
  }

  .cart-drawer__items .cart-items__table-row:has(+ .cart-items__nested-line) {
    border-bottom: none;
    margin-bottom: 0;
  }

  .cart-drawer__items .cart-items__table-row:last-child {
    border-bottom: none;
  }

  .cart-drawer__summary {
    --cart-drawer-summary-padding: var(--padding-lg);

    position: sticky;
    bottom: 0;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--gap-xl);
    padding: var(--cart-drawer-summary-padding);
    margin-top: auto;
    background-color: var(--color-background);
    /* stylelint-disable-next-line color-named */
    mask-image: linear-gradient(to bottom, transparent, black var(--cart-drawer-summary-padding));

    @media screen and (min-width: 750px) {
      --cart-drawer-summary-padding: var(--padding-2xl);
    }
  }

  .cart-drawer__dialog[cart-summary-sticky='false'] .cart-drawer__summary {
    position: static;
    mask-image: none;
  }

  .cart-drawer__dialog[cart-summary-sticky='false'] .cart-drawer__items {
    overflow: unset;
  }

  .cart-drawer__summary .cart__summary-totals:not(:has(.cart__subtotal-container:empty)) {
    border-block-start: var(--style-border-width) solid var(--color-border);
    padding-block-start: var(--padding-2xl);
  }

  .cart-drawer__summary .cart-note {
    @media screen and (min-width: 750px) {
      margin-block-start: var(--margin-3xs);
    }
  }

  .cart-drawer__heading--empty {
    display: flex;
    justify-content: center;
  }

  .cart-drawer__items {
    display: flex;
    flex-direction: column;
    padding-inline: var(--cart-drawer-padding);
    overflow-y: auto;

    @media screen and (min-width: 750px) {
      padding-inline: var(--cart-drawer-padding-desktop);
    }
  }

  .cart-drawer--empty .cart-drawer__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    height: 100dvh;
    margin-top: 0;
  }

  .cart-drawer:not(:has(.cart-form)) .cart-drawer__content {
    justify-content: center;
  }

  .cart-drawer__header {
    background-color: var(--color-background);
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: var(--cart-drawer-padding);
    border-bottom: var(--style-border-width) solid none;
    position: sticky;
    top: 0;
    z-index: 1;

    @media screen and (min-width: 750px) {
      padding-inline: var(--cart-drawer-padding-desktop);
    }
  }

  .cart-drawer--empty .cart-drawer__header {
    justify-content: right;
    border-bottom: none;
    padding-bottom: 0;
  }

  .cart-drawer--empty .cart-drawer__heading {
    text-align: center;
  }

  .cart-drawer__heading .cart-bubble {
    width: fit-content;
    border-radius: var(--style-border-radius-buttons-primary);
    aspect-ratio: auto;
    padding: var(--cart-padding);
  }

  .cart-drawer__heading .cart-bubble[data-maintain-ratio] {
    width: min(1lh, 22px);
    height: min(1lh, 22px);
  }

  .cart-drawer__heading .cart-bubble .cart-bubble__background {
    background-color: rgb(var(--color-foreground-rgb) / var(--opacity-10-25));
  }

  .cart-drawer__heading .cart-bubble__text {
    color: var(--color-foreground);
    font-size: clamp(var(--font-size--3xs), 0.75em, var(--font-size--xs));
  }

  .cart-actions summary {
    padding-inline: 0;
    padding-block: var(--padding-sm);
    line-height: 1.2;
    min-height: var(--minimum-touch-target);
  }

  /* Empty cart bubble – avoid showing an empty pill next to the icon. */
  cart-icon:has(.cart-bubble__text-count:empty) .cart-bubble {
    display: none;
  }

  /* Cart drawer view transitions (matches Horizon's defaults). */
  @media screen and (prefers-reduced-motion: no-preference) {
    html:active-view-transition-type(empty-cart-drawer) {
      .cart-drawer__close-button {
        view-transition-name: cart-drawer-close-button;
      }
    }
  }

  :active-view-transition {
    .cart-drawer__header,
    .cart-drawer__content {
      background: transparent;
    }
  }

  ::view-transition-old(cart-drawer-content) {
    transform-origin: 50% 33%;
    animation: cart-contents-old var(--spring-d280-b0-duration) var(--spring-d280-b0-easing) forwards;
  }

  ::view-transition-new(cart-drawer-content) {
    transform-origin: top center;
    animation: cart-contents-new var(--spring-d280-b0-duration) var(--spring-d280-b0-easing) forwards;
  }

  @keyframes cart-contents-old {
    to {
      scale: 0.92;
      opacity: 0;
    }
  }

  @keyframes cart-contents-new {
    from {
      scale: 1.05;
      translate: 0 128px;
      filter: blur(1px);
      opacity: 0;
    }
  }

  .header-bar__action--mobile-only {
    display: none;
  }

  @media (max-width: 749px) {
    .header-bar {
      padding: 12px 16px;
      gap: 12px;
    }

    .header-bar__menu-toggle {
      display: inline-flex;
    }

    .header-bar__search {
      display: none;
    }

    .header-bar__action--mobile-only {
      display: block;
    }

    .header-bar__action-label {
      position: absolute;
      inline-size: 1px;
      block-size: 1px;
      padding: 0;
      margin: -1px;
      overflow: hidden;
      white-space: nowrap;
      border: 0;
      clip: rect(0, 0, 0, 0);
    }

    .header-bar__actions {
      gap: 16px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Header",
  "tag": "header",
  "class": "header-bar",
  "enabled_on": {
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "text",
      "id": "brand_text",
      "label": "Brand wordmark",
      "default": "BEAUTY LUXE"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Mobile menu",
      "default": "main-menu",
      "info": "Linklist shown in the mobile menu drawer (hamburger button)."
    },
    {
      "type": "text",
      "id": "search_placeholder",
      "label": "Search placeholder",
      "default": "Search"
    },
    {
      "type": "header",
      "content": "Right actions"
    },
    {
      "type": "checkbox",
      "id": "show_search",
      "label": "Show search",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_account",
      "label": "Show sign in / account",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_wishlist",
      "label": "Show wishlist",
      "default": true
    },
    {
      "type": "url",
      "id": "wishlist_url",
      "label": "Wishlist link"
    }
  ],
  "presets": [
    {
      "name": "Header"
    }
  ]
}
{% endschema %}
