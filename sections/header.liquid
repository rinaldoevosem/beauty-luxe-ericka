{% doc %}
  Beauty Luxe header bar.

  - Desktop: text wordmark (left) | pill-shaped search button (center) | sign-in / wishlist / bag (right).
  - Mobile (≤749px): hamburger + wordmark (left) | search / account / wishlist / bag icons (right).
  - Search button opens the existing `<search-modal>` via `on:click="#search-modal/showDialog"`.
  - Hamburger is a placeholder; menu drawer wiring is a follow-up task.

  @example
  Rendered via `sections/header-group.json` with section type `header`.
{% enddoc %}

{%- liquid
  assign brand = section.settings.brand_text
  if brand == blank
    assign brand = shop.name
  endif

  assign search_placeholder = section.settings.search_placeholder
  if search_placeholder == blank
    assign search_placeholder = 'Search'
  endif

  assign wishlist_url = section.settings.wishlist_url
  if wishlist_url == blank
    assign wishlist_url = '#'
  endif

  if customer
    assign account_label = 'Account'
  else
    assign account_label = 'Sign in'
  endif
-%}

<div class="header-bar__brand-group">
  <button
    type="button"
    class="header-bar__menu-toggle"
    aria-label="Open menu"
  >
    <span class="header-bar__icon" aria-hidden="true">
      {{ 'icon-burger.svg' | inline_asset_content }}
    </span>
  </button>

  <a href="{{ routes.root_url }}" class="header-bar__logo">{{ brand | escape }}</a>
</div>

{%- if section.settings.show_search -%}
  <button
    type="button"
    class="header-bar__search"
    on:click="#search-modal/showDialog"
    aria-label="Open search"
    aria-haspopup="dialog"
  >
    <span class="header-bar__search-icon" aria-hidden="true">
      {{ 'icon-search.svg' | inline_asset_content }}
    </span>
    <span class="header-bar__search-placeholder">{{ search_placeholder | escape }}</span>
  </button>
{%- endif -%}

<ul class="header-bar__actions" role="list">
  {%- if section.settings.show_search -%}
    <li class="header-bar__action header-bar__action--mobile-only">
      <button
        type="button"
        class="header-bar__action-link"
        on:click="#search-modal/showDialog"
        aria-label="Open search"
        aria-haspopup="dialog"
      >
        <span class="header-bar__icon" aria-hidden="true">
          {{ 'icon-search.svg' | inline_asset_content }}
        </span>
      </button>
    </li>
  {%- endif -%}

  {%- if section.settings.show_account -%}
    <li class="header-bar__action">
      <a href="{{ routes.account_url }}" class="header-bar__action-link">
        <span class="header-bar__icon" aria-hidden="true">
          {{ 'User-Icon.svg' | inline_asset_content }}
        </span>
        <span class="header-bar__action-label">{{ account_label }}</span>
      </a>
    </li>
  {%- endif -%}

  {%- if section.settings.show_wishlist -%}
    <li class="header-bar__action">
      <a href="{{ wishlist_url }}" class="header-bar__action-link">
        <svg class="header-bar__icon" viewBox="0 0 20 20" fill="none" stroke="currentColor" aria-hidden="true">
          {% render 'icon', icon: 'heart' %}
        </svg>
        <span class="header-bar__action-label">Wishlist</span>
      </a>
    </li>
  {%- endif -%}

  <li class="header-bar__action header-bar__action--cart">
    <script
      src="{{ 'cart-icon.js' | asset_url }}"
      type="module"
      fetchpriority="low"
    ></script>

    {%- if settings.cart_type == 'drawer' and template.name != 'cart' -%}
      <script
        src="{{ 'cart-drawer.js' | asset_url }}"
        type="module"
        fetchpriority="low"
      ></script>

      {%- capture empty_cart_drawer_content -%}
        <div class="cart-drawer__header">
          <button
            ref="closeButton"
            on:click="cart-drawer-component/close"
            class="button close-button cart-drawer__close-button button-unstyled"
            aria-label="{{ 'actions.close_dialog' | t }}"
          >
            <span class="svg-wrapper">
              {{- 'icon-close.svg' | inline_asset_content -}}
            </span>
          </button>
        </div>

        <div
          class="cart-drawer__content"
          aria-label="{{ 'accessibility.cart' | t }}"
        >
          <h2
            class="cart-drawer__heading h4 cart-drawer__heading--empty"
            id="cart-drawer-heading-empty"
          >
            {{ 'content.your_cart_is_empty' | t }}
          </h2>

          <div class="cart-drawer__items">
            {% render 'cart-products', force_empty: true %}
          </div>
        </div>
      {%- endcapture -%}

      <cart-drawer-component
        class="cart-drawer header-bar__cart-drawer"
        {% if settings.auto_open_cart_drawer %}auto-open{% endif %}
      >
        <template id="empty-cart-template">
          {{ empty_cart_drawer_content }}
        </template>

        <button
          type="button"
          class="header-bar__action-link"
          on:click="/open"
          aria-haspopup="dialog"
          aria-label="Bag{% if cart.item_count > 0 %}, {{ cart.item_count }}{% endif %}"
          aria-describedby="cart-bubble-text"
          data-testid="cart-drawer-trigger"
        >
          <cart-icon
            class="header-bar__cart-icon{% unless cart == empty %} header-bar__cart-icon--has-cart{% endunless %}"
            data-testid="cart-icon"
          >
            <span
              class="header-bar__icon"
              aria-hidden="true"
            >
              {{ 'Cart-Icon.svg' | inline_asset_content }}
            </span>
            <span class="header-bar__action-label">Bag</span>
            {% render 'cart-bubble', limit: 100 %}
          </cart-icon>
        </button>

        <dialog
          ref="dialog"
          class="cart-drawer__dialog dialog-modal dialog-drawer color-{{ settings.drawer_color_scheme }}{% if cart.empty? %} cart-drawer--empty{% endif %}"
          data-testid="cart-drawer-dialog"
          aria-labelledby="{% if cart.empty? %}cart-drawer-heading-empty{% else %}cart-drawer-heading{% endif %}"
          scroll-lock
          cart-summary-sticky="true"
        >
          <span
            ref="liveRegion"
            class="visually-hidden"
            role="status"
          ></span>
          <div
            class="cart-drawer__inner"
            data-hydration-key="cart-drawer-inner"
          >
            {%- capture cart_items_children -%}
              {%- if cart.empty? -%}
                {{ empty_cart_drawer_content }}
              {%- else -%}
                <div
                  class="cart-drawer__header"
                  id="cart-drawer-header"
                >
                  <h2
                    class="cart-drawer__heading h4"
                    id="cart-drawer-heading"
                  >
                    {{ 'content.cart_title' | t }}
                    {% render 'cart-bubble' %}
                  </h2>

                  <button
                    ref="closeButton"
                    on:click="cart-drawer-component/close"
                    class="button close-button cart-drawer__close-button button-unstyled"
                    aria-label="{{ 'actions.close_dialog' | t }}"
                  >
                    <span class="svg-wrapper">
                      {{- 'icon-close.svg' | inline_asset_content -}}
                    </span>
                  </button>
                </div>

                <scroll-hint
                  class="cart-drawer__content"
                  aria-label="{{ 'accessibility.cart' | t }}"
                  style="--header-height: 60px;"
                >
                  <scroll-hint class="cart-drawer__items">
                    {% render 'cart-products' %}
                  </scroll-hint>

                  <div class="cart-drawer__summary">
                    {% render 'cart-summary', section_id: section.id %}
                  </div>
                </scroll-hint>
              {%- endif -%}
            {%- endcapture -%}
            {% render 'cart-items-component',
              children: cart_items_children,
              is_drawer: true,
              section_id: section.id
            %}
          </div>
        </dialog>
      </cart-drawer-component>
    {%- else -%}
      <a
        href="{{ routes.cart_url }}"
        class="header-bar__action-link"
        aria-label="Bag{% if cart.item_count > 0 %}, {{ cart.item_count }}{% endif %}"
        aria-describedby="cart-bubble-text"
      >
        <cart-icon
          class="header-bar__cart-icon{% unless cart == empty %} header-bar__cart-icon--has-cart{% endunless %}"
          data-testid="cart-icon"
        >
          <span
            class="header-bar__icon"
            aria-hidden="true"
          >
            {{ 'Cart-Icon.svg' | inline_asset_content }}
          </span>
          <span class="header-bar__action-label">Bag</span>
          {% render 'cart-bubble', limit: 100 %}
        </cart-icon>
      </a>
    {%- endif -%}
  </li>
</ul>

{% stylesheet %}
  .header-bar {
    display: flex;
    align-items: center;
    inline-size: 100%;
    gap: 24px;
    padding: 12px 30px;
    background-color: var(--color-white-100);
    color: var(--color-dark-100);
  }

  .header-bar__brand-group {
    flex: 2;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .header-bar__menu-toggle {
    display: none;
    align-items: center;
    justify-content: center;
    inline-size: 24px;
    block-size: 24px;
    padding: 0;
    border: none;
    background: transparent;
    color: var(--color-dark-100);
    cursor: pointer;
  }

  .header-bar__logo {
    font-family: var(--font-ui);
    font-size: var(--type-logo-size);
    font-weight: var(--type-logo-weight);
    line-height: var(--type-logo-lh);
    color: var(--color-dark-100);
    text-decoration: none;
    white-space: nowrap;
  }

  .header-bar__search {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    inline-size: 310px;
    block-size: 32px;
    padding: 0 12px;
    border: 1px solid var(--color-dark-100);
    border-radius: 50px;
    background: transparent;
    cursor: pointer;
    color: var(--color-dark-60);
    font-family: var(--font-body);
    font-size: var(--type-p-sm-size);
    font-weight: var(--type-p-sm-weight-light);
    line-height: var(--type-p-sm-lh);
  }

  .header-bar__search-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    inline-size: 16px;
    block-size: 16px;
    flex: 0 0 auto;
    color: currentColor;
  }

  .header-bar__search-icon svg {
    inline-size: 100%;
    block-size: 100%;
  }

  .header-bar__search-placeholder {
    color: var(--color-dark-60);
  }

  .header-bar__actions {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 20px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .header-bar__action {
    margin: 0;
  }

  .header-bar__action-link {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 0;
    border: none;
    background: transparent;
    color: var(--color-dark-60);
    text-decoration: none;
    font-family: var(--font-body);
    font-size: var(--type-p-xs-size);
    font-weight: var(--type-p-xs-weight-light);
    line-height: var(--type-p-xs-lh);
    cursor: pointer;
  }

  .header-bar__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    inline-size: 16px;
    block-size: 16px;
    flex: 0 0 auto;
    color: currentColor;
    fill: currentColor;
    stroke: currentColor;
  }

  .header-bar__icon svg {
    inline-size: 100%;
    block-size: 100%;
  }

  .header-bar__action-count {
    position: absolute;
    top: -6px;
    right: -8px;
    min-inline-size: 16px;
    block-size: 16px;
    padding: 0 4px;
    border-radius: 50px;
    background-color: var(--color-dark-100);
    color: var(--color-white-100);
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 500;
    line-height: 16px;
    text-align: center;
  }

  /* Live count badge (Horizon's <cart-bubble> rendered by cart-icon.js).
     Replaces the static .header-bar__action-count so the count updates
     in real time after add-to-cart events. */
  .header-bar__cart-icon {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }

  .header-bar__cart-icon .cart-bubble {
    position: absolute;
    top: -6px;
    right: -8px;
    width: auto;
    min-inline-size: 16px;
    block-size: 16px;
    aspect-ratio: auto;
    padding: 0 4px;
    border-radius: 50px;
    background-color: var(--color-dark-100);
  }

  .header-bar__cart-icon .cart-bubble.visually-hidden {
    display: none;
  }

  .header-bar__cart-icon .cart-bubble__background {
    display: none;
  }

  .header-bar__cart-icon .cart-bubble__text {
    color: var(--color-white-100);
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 500;
    line-height: 16px;
  }

  /* Reset Horizon's button styles inside the brand cart trigger so the
     <button on:click="/open"> looks identical to the previous <a> link. */
  button.header-bar__action-link {
    margin: 0;
    appearance: none;
    text-align: inherit;
  }

  .header-bar__action--mobile-only {
    display: none;
  }

  @media (max-width: 749px) {
    .header-bar {
      padding: 12px 16px;
      gap: 12px;
    }

    .header-bar__menu-toggle {
      display: inline-flex;
    }

    .header-bar__search {
      display: none;
    }

    .header-bar__action--mobile-only {
      display: block;
    }

    .header-bar__action-label {
      position: absolute;
      inline-size: 1px;
      block-size: 1px;
      padding: 0;
      margin: -1px;
      overflow: hidden;
      white-space: nowrap;
      border: 0;
      clip: rect(0, 0, 0, 0);
    }

    .header-bar__actions {
      gap: 16px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Header",
  "tag": "header",
  "class": "header-bar",
  "enabled_on": {
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "text",
      "id": "brand_text",
      "label": "Brand wordmark",
      "default": "BEAUTY LUXE"
    },
    {
      "type": "text",
      "id": "search_placeholder",
      "label": "Search placeholder",
      "default": "Search"
    },
    {
      "type": "header",
      "content": "Right actions"
    },
    {
      "type": "checkbox",
      "id": "show_search",
      "label": "Show search",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_account",
      "label": "Show sign in / account",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_wishlist",
      "label": "Show wishlist",
      "default": true
    },
    {
      "type": "url",
      "id": "wishlist_url",
      "label": "Wishlist link"
    }
  ],
  "presets": [
    {
      "name": "Header"
    }
  ]
}
{% endschema %}
