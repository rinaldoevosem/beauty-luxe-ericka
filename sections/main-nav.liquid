{% doc %}
  Beauty Luxe main navigation bar.

  - Full-width black bar that sits below the header on desktop.
  - Renders a Shopify linklist (default handle: main-menu).
  - Designed to hold 13 items: New · Brands · Makeup · Kits & Tools · Skincare · Hair Care · Bath & Body · Fragrance · Special FX · Best Sellers · Discover · Sales & Offers · Blog.
  - Hidden on mobile (≤749px); the hamburger in the header bar will open the drawer instead (mobile spec is a follow-up task).

  @example
  Rendered via `sections/header-group.json` with section type `main-nav`.
{% enddoc %}

{%- liquid
  assign menu = linklists[section.settings.menu]
-%}

{%- if menu.links.size > 0 -%}
  <nav class="main-nav__inner" aria-label="Main navigation">
    <ul class="main-nav__list" role="list">
      {%- for link in menu.links -%}
        <li class="main-nav__item">
          <a
            href="{{ link.url }}"
            class="main-nav__link"
            {% if link.active %}aria-current="page"{% endif %}
          >
            {{- link.title | escape -}}
          </a>
        </li>
      {%- endfor -%}
    </ul>
  </nav>
{%- endif -%}

{% stylesheet %}
  .main-nav {
    /* Non-palette: pure black bar per Beauty Luxe spec */
    background-color: #0A0A0A;
    color: var(--color-white-100);
    inline-size: 100%;
    padding: 14px var(--layout-content-padding);
  }

  .main-nav__list {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .main-nav__item {
    margin: 0;
  }

  .main-nav__link {
    display: inline-block;
    font-family: var(--font-body);
    font-size: var(--type-p-sm-size);
    font-weight: var(--type-p-lg-weight-light);
    line-height: 1;
    letter-spacing: 0.4px;
    text-transform: uppercase;
    color: var(--color-white-100);
    text-decoration: none;
    white-space: nowrap;
  }

  .main-nav__link:hover,
  .main-nav__link:focus-visible,
  .main-nav__link[aria-current='page'] {
    text-decoration: underline;
  }

  @media (max-width: 749px) {
    .main-nav {
      display: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Main navigation",
  "tag": "section",
  "class": "main-nav",
  "enabled_on": {
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu",
      "default": "main-menu",
      "info": "Edit menu items in Online Store > Navigation. Designed for 13 items."
    }
  ],
  "presets": [
    {
      "name": "Main navigation"
    }
  ]
}
{% endschema %}
