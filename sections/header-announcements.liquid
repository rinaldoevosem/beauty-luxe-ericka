{% doc %}
  Renders the Beauty Luxe announcement bar at the top of the storefront.

  - 40px full-width bar with centered, single-line copy.
  - Renders one block statically; rotates between 2-5 blocks with a CSS-only fade.
  - Uses Beauty Luxe design tokens from `snippets/theme-styles-variables.liquid`:
    `--color-dark-100`, `--color-white-100`, `--font-body`, `--type-p-sm-*`.

  @example
  Rendered via `sections/header-group.json` with section type `header-announcements`.
{% enddoc %}

{%- liquid
  assign block_count = section.blocks.size
  assign should_rotate = false
  if block_count > 1
    assign should_rotate = true
  endif
-%}

{%- if should_rotate -%}
  {%- assign per_item_seconds = 4 -%}
  {%- assign total_seconds = per_item_seconds | times: block_count -%}
  {%- assign visible_pct = 100.0 | divided_by: block_count | round: 2 -%}
  {%- assign visible_in = 3 -%}
  {%- assign visible_out = visible_pct | minus: visible_in -%}
  <style>
    #shopify-section-{{ section.id }} {
      --announcement-duration: {{ total_seconds }}s;
      --announcement-count: {{ block_count }};
    }

    @keyframes announcement-rotate-{{ section.id }} {
      0%                       { opacity: 0; }
      {{ visible_in }}%        { opacity: 1; }
      {{ visible_out }}%       { opacity: 1; }
      {{ visible_pct }}%       { opacity: 0; }
      100%                     { opacity: 0; }
    }

    #shopify-section-{{ section.id }} .announcement-bar__inner--rotating > .announcement-bar__item {
      animation-name: announcement-rotate-{{ section.id }};
      animation-duration: var(--announcement-duration);
      animation-iteration-count: infinite;
      animation-timing-function: ease-in-out;
      animation-delay: calc(var(--announcement-index) * (var(--announcement-duration) / var(--announcement-count)));
    }

    @media (prefers-reduced-motion: reduce) {
      #shopify-section-{{ section.id }} .announcement-bar__inner--rotating > .announcement-bar__item {
        animation: none;
        opacity: 0;
      }

      #shopify-section-{{ section.id }} .announcement-bar__inner--rotating > .announcement-bar__item:first-child {
        opacity: 1;
      }
    }
  </style>
{%- endif -%}

{%- if block_count > 0 -%}
  <ul
    class="announcement-bar__inner{% if should_rotate %} announcement-bar__inner--rotating{% endif %}"
    role="list"
  >
    {%- for block in section.blocks -%}
      <li
        class="announcement-bar__item"
        style="--announcement-index: {{ forloop.index0 }};"
        {{ block.shopify_attributes }}
      >
        <div class="announcement-bar__copy announcement-bar__copy--desktop">
          {{ block.settings.text }}
        </div>
        <div class="announcement-bar__copy announcement-bar__copy--mobile">
          {{ block.settings.text_mobile }}
        </div>
      </li>
    {%- endfor -%}
  </ul>
{%- endif -%}

{% stylesheet %}
  .announcement-bar {
    display: flex;
    align-items: center;
    justify-content: center;
    inline-size: 100%;
    block-size: 40px;
    padding-inline: 16px;
    overflow: hidden;
    background-color: var(--color-dark-100);
    color: var(--color-white-100);
  }

  .announcement-bar__inner {
    display: grid;
    inline-size: 100%;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .announcement-bar__item {
    grid-area: 1 / 1;
    margin: 0;
    overflow: hidden;
    font-family: var(--font-body);
    font-size: var(--type-p-sm-size);
    font-weight: var(--type-p-sm-weight-regular);
    line-height: var(--type-p-sm-lh);
    text-align: center;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .announcement-bar__item * {
    margin: 0;
  }

  .announcement-bar__copy--mobile {
    display: none;
  }

  @media (max-width: 749px) {
    .announcement-bar__copy--desktop {
      display: none;
    }

    .announcement-bar__copy--mobile {
      display: block;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Announcement Bar",
  "tag": "div",
  "class": "announcement-bar",
  "enabled_on": {
    "groups": ["header"]
  },
  "max_blocks": 5,
  "blocks": [
    {
      "type": "announcement",
      "name": "Announcement",
      "settings": [
        {
          "type": "richtext",
          "id": "text",
          "label": "Text (desktop)",
          "default": "<p>Free Shipping on Orders $50+ · Earn Rewards on Every Purchase · Join Upcoming Pro Workshops →</p>"
        },
        {
          "type": "richtext",
          "id": "text_mobile",
          "label": "Text (mobile)",
          "default": "<p>Free Shipping on Orders $50+ Join Pro →</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Announcement Bar",
      "blocks": {
        "announcement_1": {
          "type": "announcement"
        }
      },
      "block_order": ["announcement_1"]
    }
  ]
}
{% endschema %}
